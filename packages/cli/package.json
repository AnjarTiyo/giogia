{
  "name": "@giogia/cli",
  "version": "0.1.0",
  "type": "module",
  "description": "GioGia CLI - AI-first web test automation",
  "license": "ISC",
  "author": "Anjar Tiyo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AnjarTiyo/giogia.git",
    "directory": "packages/cli"
  },
  "bin": {
    "gio": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": ["testing", "cli", "automation", "ai", "playwright"],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@giogia/core": "workspace:*",
    "@giogia/browser": "workspace:*",
    "@giogia/semantic": "workspace:*",
    "@giogia/ai": "workspace:*",
    "@giogia/runner": "workspace:*",
    "commander": "^13.0.0",
    "chalk": "^5.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
