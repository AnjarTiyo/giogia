  "dependencies": {
    "@anjartiyo/giogia-core": "*",
    "@anjartiyo/giogia-browser": "*",
    "@anjartiyo/giogia-semantic": "*",
    "@anjartiyo/giogia-ai": "*",
    "@anjartiyo/giogia-runner": "*",
    "commander": "^13.0.0",
    "chalk": "^5.4.0"
