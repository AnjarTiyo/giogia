{
  "name": "@anjartiyo/giogia-cli",
  "version": "0.1.6",
  "type": "module",
  "description": "GioGia CLI - AI-first web test automation",
  "license": "ISC",
  "author": "Anjar Tiyo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AnjarTiyo/giogia.git",
    "directory": "packages/cli"
  },
  "bin": {
    "giogia": "./dist/index.js"
  },
