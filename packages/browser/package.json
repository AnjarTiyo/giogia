{
  "name": "@giogia/browser",
  "version": "0.1.0",
  "type": "module",
  "description": "Playwright browser adapter for GioGia",
  "license": "ISC",
  "author": "Anjar Tiyo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AnjarTiyo/giogia.git",
    "directory": "packages/browser"
  },
  "main": "./dist/index.js",
