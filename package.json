{
  "name": "giogia",
  "version": "0.1.0",
  "private": true,
  "description": "AI-first web test automation framework",
  "workspaces": [
    "packages/*",
    "tests"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc -b --noEmit",
    "clean": "npm run clean --workspaces"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "tsup": "^8.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
